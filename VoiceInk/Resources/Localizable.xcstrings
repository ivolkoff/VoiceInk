        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "AI-улучшение позволяет пропускать расшифрованное аудио через LLM для постобработки разными промптами под разные задачи: письма, резюме, тексты и т.д."
          }
        }
      }
    },
